# BWF Virtual Seats — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# Source of truth for keys: design/07-convex-pivot.md §12.

# --- Convex ---
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
CONVEX_DEPLOY_KEY=

# --- Convex Auth (set inside Convex env via `npx convex env set`) ---
AUTH_RESEND_KEY=
JWT_PRIVATE_KEY=

# --- Site ---
SITE_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (transactional, separate from Convex Auth's Resend key) ---
RESEND_API_KEY=
EMAIL_FROM=seats@bobwillisfund.org

# --- Address lookup ---
GETADDRESS_API_KEY=

# --- Admin allowlist ---
ADMIN_EMAILS=

# --- Feature flags ---
ENABLE_AVATARS=true
ENABLE_PRIZE_DRAW=true
ENABLE_GIFT_AID=true
